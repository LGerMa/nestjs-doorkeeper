{
  "name": "@lgerma/nestjs-doorkeeper",
  "version": "1.0.1",
  "description": "Drop-in NestJS authentication library with JWT, refresh tokens, session tracking, and device detection — inspired by Rails Doorkeeper",
  "keywords": [
    "nestjs",
    "auth",
    "authentication",
    "jwt",
    "refresh-token",
    "session",
    "typeorm",
    "doorkeeper"
  ],
  "author": "lgerma",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lgerma/nestjs-doorkeeper.git"
  },
  "homepage": "https://github.com/lgerma/nestjs-doorkeeper#readme",
  "bugs": {
    "url": "https://github.com/lgerma/nestjs-doorkeeper/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./guards": {
      "types": "./dist/guards/index.d.ts",
      "import": "./dist/guards/index.mjs",
      "require": "./dist/guards/index.js"
    },
    "./decorators": {
      "types": "./dist/decorators/index.d.ts",
      "import": "./dist/decorators/index.mjs",
      "require": "./dist/decorators/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.mjs",
      "require": "./dist/services/index.js"
    },
    "./entities": {
      "types": "./dist/entities/index.d.ts",
      "import": "./dist/entities/index.mjs",
      "require": "./dist/entities/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.mjs",
      "require": "./dist/adapters/index.js"
    }
  },
  "bin": {
    "nestjs-doorkeeper": "./bin/doorkeeper.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/typeorm": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.5.0",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.5.1",
    "typeorm": "^0.3.28",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/jwt": "^10.0.0 || ^11.0.0",
    "@nestjs/typeorm": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.0 || ^0.2.0",
    "typeorm": "^0.3.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0"
  }
}
